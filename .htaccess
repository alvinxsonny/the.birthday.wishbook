# The Birthday Wishbook — Apache Rewrite Rules
# Compatible with InfinityFree and localhost

RewriteEngine On

# Redirect /wish/TOKEN to wishlist.php?token=TOKEN
RewriteRule ^wish/([a-zA-Z0-9]+)$ wishlist.php?token=$1 [L,QSA]

# Prevent directory listing
Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Prevent access to sensitive files
<FilesMatch "\.(sql|md|json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# PHP settings (may be overridden by server)
<IfModule mod_php.c>
    php_value upload_max_filesize 2M
    php_value post_max_size 8M
    php_value max_execution_time 30
</IfModule>
